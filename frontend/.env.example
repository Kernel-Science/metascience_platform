# Metascience Frontend Environment Configuration
# Copy this file to `.env.local` and fill in the values.

# ─── Required: Supabase (auth + database) ────────────────────────────────────
# From your Supabase project: Settings > API.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Required: Site URL for auth callbacks ───────────────────────────────────
# Use http://localhost:3000 for local development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Required: Backend (FastAPI) engine URL ──────────────────────────────────
# The Python backend that powers search, citations, trends, and review.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ─── Required for the Assistant (chat) ───────────────────────────────────────
# The chat assistant calls Claude directly from the Next.js server via the
# Vercel AI SDK. Get a key at https://console.anthropic.com/.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Required for the public Developer API (/api/v1) ─────────────────────────
# Server-only Supabase service-role key, used to verify incoming API keys.
# NEVER prefix this with NEXT_PUBLIC_ and never expose it to the browser.
# From Supabase: Settings > API > service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
