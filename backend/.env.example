# Metascience Backend Environment Configuration

# Required: API Keys for AI Services
# Get your keys at: https://console.anthropic.com/ and https://aistudio.google.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# --- Models (rolling "latest" aliases; override only if you need to pin) -
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_REVIEW_MODEL=gemini-flash-latest

# --- Literature sources -------------------------------------------------
# OpenAlex polite-pool email (no signup, just an address). Strongly recommended.
OPENALEX_MAILTO=you@example.org
# Semantic Scholar API key (free: https://www.semanticscholar.org/product/api). Optional.
# (SEMANTIC_SCHOLAR_API is also accepted as an alias for this name.)
SEMANTIC_SCHOLAR_API_KEY=
# NASA ADS token (free: https://ui.adsabs.harvard.edu/user/settings/token). Optional; enables astro source.
ADS_API_TOKEN=

# --- Reviewer3 (multi-reviewer peer review) ------------------------------
# Service-account API key (sk_...). Provisioned by the Reviewer3 team.
REVIEWER3_API_KEY=
# Reviewer3 user id (usr_...) that owns submitted reviews. Required for
# submissions; ask the Reviewer3 team (the key cannot look up/create users).
REVIEWER3_USER_ID=
# Override only for local Reviewer3 development.
# REVIEWER3_BASE_URL=https://reviewer3.com

# --- Semantic rerank ----------------------------------------------------
# auto -> Google embeddings, fall back to Anthropic LLM rerank
# google -> embeddings only | anthropic -> LLM only | none -> disabled
RERANK_PROVIDER=auto
EMBEDDING_MODEL=gemini-embedding-001
# Candidates over-fetched per source before merge/dedup/rerank.
SEARCH_CANDIDATES_PER_SOURCE=120

# Optional: Supabase Configuration (for future database migration)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Server Configuration
# PORT=8000
# HOST=0.0.0.0
# LOG_LEVEL=info

# Optional: Feature Flags
# ENABLE_CACHING=false
# CACHE_TTL=3600

